// InstaReply — Prisma Schema
// Instagram Comment → Auto-DM SaaS

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  plan      Plan     @default(FREE)

  // Instagram connection
  instagramId       String?   @unique
  instagramUsername  String?
  accessToken       String? // encrypted via AES-256-GCM
  tokenExpiresAt    DateTime?

  automations Automation[]
  dmLogs      DmLog[]
}

model Automation {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  postId    String // Instagram Media ID
  postUrl   String?
  keywords  String[] // e.g. ["LINK", "PRICE", "INFO"]
  dmMessage String // The DM to send
  isActive  Boolean  @default(true)

  // Whether to match whole words only (false = partial match allowed)
  wholeWordMatch Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dmLogs DmLog[]

  @@index([postId])
  @@index([userId])
}

model DmLog {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  commenterId   String // Instagram user ID who commented
  commenterName String?
  commentText   String
  commentId     String    @unique // dedup key
  dmSentAt      DateTime?
  status        DmStatus  @default(PENDING)
  errorMessage  String?

  createdAt DateTime @default(now())

  @@index([automationId])
  @@index([userId])
  @@index([commentId])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([processed])
}

enum Plan {
  FREE
  PRO
  AGENCY
}

enum DmStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_DEDUP
  SKIPPED_RATE_LIMIT
}
